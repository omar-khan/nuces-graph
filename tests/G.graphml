      <data key="d0">3</data>
    </node>
    <node id="n4">
      <data key="d0">4</data>
    </node>
    <edge id="e0" source="n3" target="n1">
      <data key="d1">1</data>
    </edge>
    <edge id="e1" source="n2" target="n0">
      <data key="d1">1</data>
    </edge>
    <edge id="e2" source="n3" target="n0">
      <data key="d1">1</data>
    </edge>
    <edge id="e3" source="n1" target="n2">
